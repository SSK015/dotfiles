{
  "mcpServers": {
    "openmemory": {
      "command": "npx",
      "args": ["-y", "@peakmojo/mcp-openmemory"],
      "env": {
        "MEMORY_DB_PATH": "${WORKSPACE_ROOT}/.cursor/openmemory.sqlite"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@jschuller/perplexity-mcp"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "PERPLEXITY_MODEL": "sonar"
      }
    },
    "clangd-language-server": {
      "command": "npx",
      "args": ["-y", "@iflow-mcp/felipeerias-clangd-mcp-server"],
      "env": {
        "PROJECT_ROOT": "${WORKSPACE_ROOT}"
      }
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp?exaApiKey=82640f63-d2a2-4a53-8e3b-c54201b84bf7&tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa,company_research_exa,people_search_exa,deep_researcher_start,deep_researcher_check"
    }
  }
}