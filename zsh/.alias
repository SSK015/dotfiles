alias p3i="pip3 install"

# --- Modern CLI Tools Aliases ---
# eza: A modern replacement for 'ls'
if command -v eza >/dev/null 2>&1; then
    alias ls="eza --icons --group-directories-first"
    alias ll="eza -lbF --icons --group-directories-first"
    alias la="eza -labF --icons --group-directories-first"
    alias lt="eza --tree --level=2 --icons"
fi

# zoxide: A smarter 'cd' command
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh)"
    alias cd="z"
fi

# lazygit: Terminal UI for git
if command -v lazygit >/dev/null 2>&1; then
    alias lg="lazygit"
fi

# bat: A modern replacement for 'cat'
if command -v bat >/dev/null 2>&1; then
    alias cat="bat"
elif command -v batcat >/dev/null 2>&1; then
    alias cat="batcat"
fi

# ripgrep: A modern replacement for 'grep'
if command -v rg >/dev/null 2>&1; then
    alias grep="rg"
fi

# dust: A modern replacement for 'du'
if command -v dust >/dev/null 2>&1; then
    alias du="dust"
fi
# --------------------------------

myalias() {
    echo "The first parameter is $1"
    echo "The second parameter is $2"
}

catgrep() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: catgrep <file_path> <key_word> <neighbor_lines(optional, default=0)>"
        return 1
    fi
    if [ -z "$3" ]; then
        cat $1 | grep $2 -C 0
    fi
    cat $1 | grep $2 -C $3
}

zcatgrep() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: zcatgrep <file_path> <key_word> <neighbor_lines(optional, default=0)>"
        return 1
    fi
    if [ -z "$3" ]; then
        zcat $1 | grep $2 -C 0
    fi
    zcat $1 | grep $2 -C $3
}

filefind() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: dirfind <dir_path> <key_word>"
        return 1
    fi
    # find /usr -name 'libboost_program_options*'
    find $1 -name $2
}

strgrep() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: strgrep <lib_path> <key_word>"
        return 1
    fi
    strings $1 | grep $2
    # strings /usr/local/lib/libboost_program_options.so.1.71.0 | grep GCC
}

gengrep() {
    if [ -z "$1" ] || [ -z "$2" ] || [ -z "$3" ]; then
        echo "Usage: gengrep <command> <file_path> <key_word> <neighbor_lines(optional, default=0)>"
        return 1
    fi
    if [ -z "$4" ]; then
        $1 $2 | grep $3 -C 0
    else
        $1 $2 | grep $3 -C $4
    fi
}

gclb() {
    if [ -z "$1" ]; then
        echo "Usage: gclb <git_url> <branch_name>"
        return 1
    fi
    if [ -z "$2" ]; then
        git clone $1
    else
        git clone $1 -b $2 $3
    fi
}

gclrb() {
    if [ -z "$1" ]; then
        echo "Usage: gclb <git_url> <branch_name>"
        return 1
    fi
    if [ -z "$2" ]; then
        git clone --recurse-submodules $1
    else
        git clone $1 --recurse-submodules -b $2 $3
    fi
}
